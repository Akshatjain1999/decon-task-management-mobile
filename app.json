{
  "expo": {
    "name": "Decon Task Manager",
    "slug": "decon-task-management-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.crm.decontaskmanager"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.crm.decontaskmanager",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sharing",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#006a66",
          "defaultChannel": "default",
          "sounds": []
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Decon Task Manager uses the camera for barcode scanning.",
          "enableCodeScanner": true
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "79d6d060-070a-4e52-aee6-86ed7e73f3a5"
      }
    },
    "owner": "akshatjain1999"
  }
}
